RewriteEngine On

# Redirect file-based URLs to clean public slugs.
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^about\.html$ /about/ [R=301,L]
RewriteRule ^services\.html$ /services/ [R=301,L]
RewriteRule ^singleService\.html$ /services/skills-assessment-support/ [R=301,L]
RewriteRule ^migrationCode\.html$ /professional-standards/ [R=301,L]
RewriteRule ^blogListing\.html$ /blog/ [R=301,L]
RewriteRule ^blogSinglePost\.html$ /blog/choose-the-right-australian-visa-pathway/ [R=301,L]
RewriteRule ^blogTimelinePost\.html$ /blog/moving-to-australia-visa-timeline/ [R=301,L]
RewriteRule ^contactUs\.html$ /contact/ [R=301,L]
RewriteRule ^clientForm\.html$ /book-a-consultation/ [R=301,L]
RewriteRule ^consultationTerms\.html$ /consultation-terms/ [R=301,L]
RewriteRule ^privacyPolicy\.html$ /privacy-policy/ [R=301,L]
RewriteRule ^websiteTermsOfUse\.html$ /website-terms-of-use/ [R=301,L]

# Internally rewrite clean slugs to the existing static HTML files.
RewriteRule ^about/?$ /about.html [L]
RewriteRule ^services/?$ /services.html [L]
RewriteRule ^services/skills-assessment-support/?$ /singleService.html [L]
RewriteRule ^professional-standards/?$ /migrationCode.html [L]
RewriteRule ^blog/?$ /blogListing.html [L]
RewriteRule ^blog/choose-the-right-australian-visa-pathway/?$ /blogSinglePost.html [L]
RewriteRule ^blog/moving-to-australia-visa-timeline/?$ /blogTimelinePost.html [L]
RewriteRule ^contact/?$ /contactUs.html [L]
RewriteRule ^book-a-consultation/?$ /clientForm.html [L]
RewriteRule ^consultation-terms/?$ /consultationTerms.html [L]
RewriteRule ^privacy-policy/?$ /privacyPolicy.html [L]
RewriteRule ^website-terms-of-use/?$ /websiteTermsOfUse.html [L]
